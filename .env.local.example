# Google OAuth（Google Cloud Consoleで取得したクライアントIDとシークレット）
GOOGLE_CLIENT_ID=ここにクライアントIDを貼り付け
GOOGLE_CLIENT_SECRET=ここにクライアントシークレットを貼り付け

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=ここにランダムな文字列を入力（例: openssl rand -base64 32 の結果）

# Stripe（Stripeダッシュボード → 開発者 → APIキー）
STRIPE_SECRET_KEY=sk_test_...
# Webhookシークレット（本番はStripeダッシュボードのWebhookエンドポイントから取得）
# 開発中はwhsec_placeholderのままでOK（Webhookをスキップ）
STRIPE_WEBHOOK_SECRET=whsec_placeholder
